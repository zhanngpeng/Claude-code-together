# 自定义 OpenAI 兼容 API 配置
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://your-custom-api-endpoint.com/v1

# 用于生成大纲的模型（如 gpt-4o, deepseek-chat 等）
CHAT_MODEL=gpt-4o

# Whisper 语音转文字模型（如支持则走 API，否则自动降级为本地）
# 如果你的 API 源支持 Whisper: true  否则: false
USE_WHISPER_API=true
WHISPER_MODEL=whisper-1

# 输出目录（默认为当前目录下的 output 文件夹）
OUTPUT_DIR=./output
